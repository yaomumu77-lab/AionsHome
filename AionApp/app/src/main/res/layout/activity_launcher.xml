<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1a1a2e">

    <!-- Logo / 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textColor="#ff8359"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择连接方式"
        android:textSize="15sp"
        android:textColor="#aaaaaa"
        android:layout_marginBottom="40dp" />

    <!-- 家庭 WiFi -->
    <Button
        android:id="@+id/btnHome"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="🏠  家庭 WiFi"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#2d5a3d"
        android:padding="16dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvHomeUrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <!-- 户外 Cloudflare -->
    <Button
        android:id="@+id/btnCloudflare"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="⚡  户外 Cloudflare"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#5f4a1d"
        android:padding="16dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvCloudflareUrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <!-- 户外 Tailscale -->
    <Button
        android:id="@+id/btnOutdoor"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="🌐  户外 Tailscale"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#2d4a6e"
        android:padding="16dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvOutdoorUrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp" />

    <!-- 记住选择 -->
    <CheckBox
        android:id="@+id/cbRemember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="记住选择，下次自动连接"
        android:textSize="13sp"
        android:textColor="#888888"
        android:buttonTint="#ff8359" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="手势返回到首页可切换地址\n局域网 / Cloudflare / Tailscale 三线可选"
        android:textSize="11sp"
        android:textColor="#555555"
        android:layout_marginTop="16dp" />

</LinearLayout>
